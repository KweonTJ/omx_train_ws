<mujoco model="turtlebot3_manipulator_dummy">
  <compiler angle="radian" meshdir="meshes"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <worldbody>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.8 0.8 0.8 1"/>

    <body name="base" pos="0 0 0.08">
      <freejoint/>
      <geom name="base_geom" type="box" size="0.14 0.11 0.04" mass="2.0" rgba="0.1 0.1 0.1 1"/>

      <body name="arm_link1" pos="0.08 0 0.08">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.08" size="0.015" mass="0.1"/>

        <body name="arm_link2" pos="0 0 0.08">
          <joint name="joint2" type="hinge" axis="0 1 0" range="-1.5 1.5"/>
          <geom type="capsule" fromto="0 0 0 0.12 0 0" size="0.015" mass="0.1"/>

          <body name="arm_link3" pos="0.12 0 0">
            <joint name="joint3" type="hinge" axis="0 1 0" range="-2.7 1.38"/>
            <geom type="capsule" fromto="0 0 0 0.12 0 0" size="0.015" mass="0.1"/>

            <body name="arm_link4" pos="0.12 0 0">
              <joint name="joint4" type="hinge" axis="0 1 0" range="-1.79 2.04"/>
              <geom type="capsule" fromto="0 0 0 0.08 0 0" size="0.012" mass="0.05"/>

              <body name="eef" pos="0.08 0 0">
                <geom name="gripper" type="box" size="0.025 0.04 0.015" mass="0.05" rgba="0.2 0.2 1 1"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <body name="object" pos="0.45 0 0.04">
      <freejoint/>
      <geom name="object_geom" type="box" size="0.03 0.03 0.03" mass="0.05" rgba="1 0 0 1"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="1"/>
    <motor name="joint2_motor" joint="joint2" gear="1"/>
    <motor name="joint3_motor" joint="joint3" gear="1"/>
    <motor name="joint4_motor" joint="joint4" gear="1"/>
  </actuator>
</mujoco>
